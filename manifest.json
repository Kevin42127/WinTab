{
  "manifest_version": 3,
  "name": "WinTab",
  "version": "1.1.0",
  "description": "Windows 10 style new tab with clock, search, shortcuts and start menu",
  "permissions": [
    "storage",
    "topSites",
    "identity"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "WinTab",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
